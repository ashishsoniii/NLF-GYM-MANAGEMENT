# Copy to .env and fill in real values. Never commit .env.

PORT=3001

# MongoDB connection string (replace with your cluster URI)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Strong random string for signing JWTs (e.g. openssl rand -base64 32)
JWT_SECRET=your_secure_jwt_secret_here

# Comma-separated allowed frontend origins for CORS (no spaces after commas)
# e.g. https://your-app.vercel.app,https://www.yourdomain.com
FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Email - Option 1: Brevo (FREE, no domain needed, 300 emails/day)
# Sign up at https://brevo.com, go to SMTP & API > API Keys
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
# EMAIL_FROM=your@gmail.com
# EMAIL_FROM_NAME=NLF Gym

# Email - Option 2: Gmail SMTP (works locally, blocked on most cloud hosts)
# EMAIL=your@gmail.com
# EMAIL_PASSWORD=app_password

# Razorpay (for member portal payments)
# RAZORPAY_KEY_ID=rzp_test_xxxx
# RAZORPAY_KEY_SECRET=xxxx
